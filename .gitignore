# ===========================================================================
# .gitignore — raiz do repositório nlconsulting-ai-auditor
# ===========================================================================

# Ambientes virtuais
venv/
.venv/
env/

# Segredos — NUNCA devem ser versionados
.env
.env.*
!.env.example

# Cache Python
__pycache__/
*.py[cod]
*.pyo

# Dados de entrada (notas fiscais dos clientes)
arquivos_nf/
*.zip

# Docker
backend/.dockerignore

# Editores e IDEs
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
